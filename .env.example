# 環境変数テンプレート
# このファイルを .env にコピーして値を更新してください

# データベース
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_EXPIRE_MINUTES=

# Google認証
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL設定
FRONTEND_URL=
BACKEND_URL=

# CORS設定 (カンマ区切りで複数指定可能)
ALLOWED_ORIGINS=

# 環境
ENVIRONMENT=
LOG_LEVEL=
